generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  LOCKED
}

enum NewsAudience {
  PUBLIC
  MEMBERS
  STAFF
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum MatrimonyStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

model User {
  id                     String               @id @default(cuid())
  email                  String               @unique
  phone                  String?              @unique
  passwordHash           String
  role                   UserRole             @default(MEMBER)
  status                 UserStatus           @default(ACTIVE)
  firstName              String
  lastName               String?
  dateOfBirth            DateTime?
  gender                 String?
  occupation             String?
  addressLine1           String?
  addressLine2           String?
  area                   String?
  city                   String?
  state                  String?
  postalCode             String?
  country                String               @default("India")
  profilePhotoUrl        String?
  familyVisibilityPublic Boolean              @default(false)
  emailVerifiedAt        DateTime?
  lastLoginAt            DateTime?
  failedLoginCount       Int                  @default(0)
  lockedUntil            DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  deletedAt              DateTime?

  families               FamilyMember[]
  refreshTokens          RefreshToken[]
  passwordResets         PasswordResetToken[]
  auditLogs              AuditLog[]           @relation("AuditActor")
  newsCreated            NewsPost[]           @relation("NewsAuthor")
  galleryCreated         GalleryAlbum[]       @relation("GalleryAuthor")
  paymentsRecorded       Payment[]            @relation("PaymentRecorder")
  matrimonyProfile       MatrimonyProfile?    @relation("MatrimonyOwner")
  notifications          Notification[]       @relation("NotificationRecipient")
}

model RefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FamilyMember {
  id          String   @id @default(cuid())
  userId      String
  relationship String
  firstName   String
  lastName    String?
  dateOfBirth DateTime?
  occupation  String?
  photoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NewsPost {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  body        String
  imageUrl    String?
  audience    NewsAudience   @default(MEMBERS)
  scheduledAt DateTime?
  publishedAt DateTime?
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  createdBy   User          @relation("NewsAuthor", fields: [createdById], references: [id], onDelete: Restrict)
}

model GalleryAlbum {
  id          String          @id @default(cuid())
  title       String
  description String?
  coverUrl    String?
  isPublic    Boolean         @default(true)
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  createdBy   User            @relation("GalleryAuthor", fields: [createdById], references: [id], onDelete: Restrict)
  images      GalleryImage[]
}

model GalleryImage {
  id        String   @id @default(cuid())
  albumId   String
  imageUrl  String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  album     GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId])
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  recordedById   String
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("INR")
  purpose        String
  referenceNo    String        @unique
  gatewayTxnId   String?
  status         PaymentStatus @default(PENDING)
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  recorder       User          @relation("PaymentRecorder", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([recordedById])
}

model MatrimonyProfile {
  id              String          @id @default(cuid())
  userId          String          @unique
  status          MatrimonyStatus @default(DRAFT)
  headline        String?
  aboutMe         String?
  education       String?
  profession      String?
  location        String?
  heightCm        Int?
  age             Int?
  religion        String?
  caste           String?
  publicVisible   Boolean         @default(false)
  approvedAt      DateTime?
  approvedById    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  owner           User            @relation("MatrimonyOwner", fields: [userId], references: [id], onDelete: Cascade)
  photos          MatrimonyPhoto[]

  @@index([status])
  @@index([userId])
}

model MatrimonyPhoto {
  id          String   @id @default(cuid())
  profileId   String
  imageUrl    String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  profile     MatrimonyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor      User     @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([actorId])
  @@index([entityType, entityId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  body        String
  readAt      DateTime?
  sentAt      DateTime @default(now())
  data        Json?

  recipient   User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
