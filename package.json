{
  "name": "matrimonial",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --dir apps/api dev",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:mobile": "pnpm --dir apps/mobile dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "db:generate": "pnpm --dir apps/api prisma generate",
    "db:migrate": "pnpm --dir apps/api prisma migrate dev",
    "db:seed": "pnpm --dir apps/api prisma db seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.13",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.37.0",
    "typescript": "^5.8.3"
  }
}
